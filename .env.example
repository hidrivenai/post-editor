# Claude authentication (choose one):
# Option 1: API key (from console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Option 2: OAuth token (from 'claude setup-token', uses Max/Pro plan credits)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# Option 3: Full credentials JSON (legacy, from ~/.claude/.credentials.json)
# CLAUDE_CREDENTIALS_JSON={"claudeAiOauth":{"accessToken":"...","refreshToken":"...","expiresAt":0}}

# Google Drive
GDRIVE_REMOTE=gdrive:HIdrivenAI/hidrivenai_obsidian
POLL_INTERVAL_SECONDS=300
RCLONE_CONFIG_GDRIVE_TYPE=drive
RCLONE_CONFIG_GDRIVE_SCOPE=drive
RCLONE_CONFIG_GDRIVE_TOKEN={"access_token":"...","refresh_token":"...","expiry":"..."}
